{
  "name": "vocab-bot-monorepo",
  "private": true,
  "workspaces": [
    "packages/shared",
    "backend",
    "frontend",
    "bot"
  ],
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:bot": "npm run dev --prefix bot",
    "dev:all": "concurrently -n backend,frontend,bot -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:bot\"",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:generate": "npm run db:generate --prefix backend",
    "build:shared": "npm run build -w @vocab-bot/shared",
    "build:backend": "npm run build -w vocab-bot-backend",
    "build:frontend": "npm run build -w vocab-bot-frontend",
    "build:bot": "npm run build -w vocab-bot",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend && npm run build:bot",
    "vercel-build": "node scripts/vercel-build.mjs",
    "typecheck": "npm run build:shared && npm run typecheck -w @vocab-bot/shared && npm run typecheck -w vocab-bot-backend && npm run typecheck -w vocab-bot-frontend && npm run typecheck -w vocab-bot",
    "test": "npm run test -w vocab-bot-backend",
    "lint": "npm run lint -w vocab-bot-frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml}\""
  },
  "devDependencies": {
    "@vercel/node": "^5.8.17",
    "concurrently": "^9.2.1",
    "prettier": "^3.3.3"
  }
}
