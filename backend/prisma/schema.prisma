generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int       @id @default(autoincrement())
  userName                 String    @map("user_name")
  email                    String?   @unique
  telegramId               BigInt?   @unique @map("telegram_id") @db.BigInt
  telegramUsername         String?   @map("telegram_username")
  previousEmailForRecovery String?   @unique @map("previous_email_for_recovery")
  role                     String    @default("user")
  deletedAt                DateTime? @map("deleted_at")
  emailVerifiedAt          DateTime? @map("email_verified_at")
  qualificationCompletedAt DateTime? @map("qualification_completed_at")
  isGuest                  Boolean   @default(false) @map("is_guest")
  primaryLanguageId        Int?      @map("primary_language_id")
  learningLanguageId       Int?      @map("learning_language_id")
  createdAt                DateTime  @default(now()) @map("created_at")

  auth                    Auth?
  subscription            Subscription?
  payments                Payment[]
  qualificationSubmission QualificationSubmission?
  feedbackEntries         UserFeedback[]
  aiUsageAnalytics        AiUsageAnalytics[]
  telegramLinkCodes       TelegramLinkCode[]
  createdDictionaries     Dictionary[]     @relation("CreatedDictionaries")
  userDictionaries        UserDictionary[]
  primaryLanguage         Language? @relation("PrimaryLanguage", fields: [primaryLanguageId], references: [id])
  learningLanguage        Language? @relation("LearningLanguage", fields: [learningLanguageId], references: [id])

  @@map("users")
}

model TelegramLinkCode {
  id        String                 @id @default(uuid()) @db.Uuid
  userId    Int                    @map("user_id")
  code      String                 @unique
  initiator TelegramLinkInitiator  @default(web) @map("initiator")
  expiresAt DateTime               @map("expires_at")
  usedAt    DateTime?              @map("used_at")
  createdAt DateTime               @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("telegram_link_codes")
}

enum TelegramLinkInitiator {
  web
  telegram
}

enum PaymentTransactionType {
  payment
  refund
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum SubscriptionPlanCode {
  basic
  premium
}

enum SubscriptionStatus {
  active
  canceled
  past_due
}

model Payment {
  id                    String                 @id @default(uuid()) @db.Uuid
  date                  DateTime               @default(now())
  userId                Int                    @map("user_id")
  amount                Float
  currency              String                 @default("USD")
  status                PaymentStatus          @default(succeeded)
  provider              String?
  providerTransactionId String?                @map("provider_transaction_id")
  description           String?
  metadata              Json?
  originalPaymentId     String?                @map("original_payment_id") @db.Uuid
  refundReason          String?                @map("refund_reason")
  transactionType       PaymentTransactionType @map("transaction_type")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalPayment Payment?       @relation("PaymentRefund", fields: [originalPaymentId], references: [id], onDelete: SetNull)
  refunds         Payment[]      @relation("PaymentRefund")
  subscriptions   Subscription[]

  @@index([userId, date(sort: Desc)])
  @@map("payments")
}

model Subscription {
  id               String               @id @default(uuid()) @db.Uuid
  userId           Int                  @unique @map("user_id")
  planCode         SubscriptionPlanCode @map("plan_code")
  status           SubscriptionStatus
  currentPeriodEnd DateTime?            @map("current_period_end")
  createdAt        DateTime             @default(now()) @map("created_at")
  paymentId        String?              @map("payment_id") @db.Uuid

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("subscriptions")
}

model Auth {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  passwordHash String?  @map("password_hash")
  googleSub    String?  @unique @map("google_sub")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth")
}

model AppSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model AiUsageAnalytics {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  Int?     @map("user_id")
  feature                 String   @default("general")
  status                  String
  sourceTextLength        Int      @default(0) @map("source_text_length")
  estimatedTokens         Int      @default(0) @map("estimated_tokens")
  aiInputTokens           Int?     @map("ai_input_tokens")
  aiOutputTokens          Int?     @map("ai_output_tokens")
  aiTotalTokens           Int?     @map("ai_total_tokens")
  aiModel                 String?  @map("ai_model")
  errorMessage            String?  @map("error_message")
  createdAt               DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_usage_analytics")
}

model QualificationSubmission {
  id          String   @id @default(uuid()) @db.Uuid
  userId      Int      @unique @map("user_id")
  answers     Json
  submittedAt DateTime @default(now()) @map("submitted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([submittedAt(sort: Desc)])
  @@map("qualification_submissions")
}

model UserFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    Int      @map("user_id")
  category  String
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("user_feedback")
}

model Language {
  id            Int    @id @default(autoincrement()) @map("id")
  name          String @unique @map("name")

  vocabWords    VocabWord[]   @relation("LanguageVocabWords")
  lexicalNests  LexicalNest[]
  primaryUsers  User[]        @relation("PrimaryLanguage")
  learningUsers User[]        @relation("LearningLanguage")

  @@map("languages")
}

model LexicalNest {
  id         Int      @id @default(autoincrement()) @map("id")
  languageId Int      @map("language_id")
  createdAt  DateTime @default(now()) @map("created_at")

  language Language    @relation(fields: [languageId], references: [id])
  members  VocabWord[]

  @@index([languageId])
  @@map("lexical_nests")
}

model VocabWord {
  id         Int    @id @default(autoincrement()) @map("id")
  languageId Int    @map("language_id")
  nestId     Int    @map("nest_id")
  text       String @map("text")

  language     Language    @relation("LanguageVocabWords", fields: [languageId], references: [id])
  nest         LexicalNest @relation(fields: [nestId], references: [id])
  pairsAsWordA VocabPair[] @relation("WordA")
  pairsAsWordB VocabPair[] @relation("WordB")

  @@unique([languageId, text])
  @@index([nestId])
  @@map("vocab_words")
}

enum VocabPairRelationType {
  translation
  synonym
  antonym
  cognate
  inflection
}

model VocabPair {
  id                 Int                   @id @default(autoincrement()) @map("id")
  wordAId            Int                   @map("word_a_id")
  wordBId            Int                   @map("word_b_id")
  relationType       VocabPairRelationType @default(translation) @map("relation_type")
  primaryLanguageId  Int?                  @map("primary_language_id")
  learningLanguageId Int?                  @map("learning_language_id")
  partOfSpeech       String?               @map("part_of_speech")
  example            String?               @db.Text

  wordA            VocabWord         @relation("WordA", fields: [wordAId], references: [id])
  wordB            VocabWord         @relation("WordB", fields: [wordBId], references: [id])
  dictionaryEntries DictionaryEntry[]
  tags             VocabPairTag[]

  @@unique([wordAId, wordBId, relationType])
  @@map("vocab_pairs")
}

model Tag {
  id        Int      @id @default(autoincrement()) @map("id")
  name      String   @unique @map("name")
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent     Tag?           @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children   Tag[]          @relation("TagHierarchy")
  vocabPairs VocabPairTag[]

  @@index([parentId])
  @@map("tags")
}

model VocabPairTag {
  vocabPairId Int      @map("vocab_pair_id")
  tagId       Int      @map("tag_id")
  createdAt   DateTime @default(now()) @map("created_at")

  vocabPair VocabPair @relation(fields: [vocabPairId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([vocabPairId, tagId])
  @@index([tagId])
  @@map("vocab_pair_tags")
}

model Dictionary {
  id        Int      @id @default(autoincrement())
  creatorId Int      @map("creator_id")
  name      String   @default("My dictionary") @map("name")
  createdAt DateTime @default(now()) @map("created_at")

  creator User              @relation("CreatedDictionaries", fields: [creatorId], references: [id], onDelete: Cascade)
  entries DictionaryEntry[]
  members UserDictionary[]

  @@index([creatorId])
  @@map("dictionaries")
}

model DictionaryEntry {
  dictionaryId              Int      @map("dictionary_id")
  vocabPairId               Int      @map("vocab_pair_id")
  pimsleurLevel             Int      @default(0) @map("pimsleur_level")
  nextReviewMs              BigInt   @map("next_review_ms") @db.BigInt
  pimsleurLevelReverse      Int      @default(0) @map("pimsleur_level_reverse")
  nextReviewMsReverse       BigInt   @map("next_review_ms_reverse") @db.BigInt
  alternatePrimaryAnswers   String[] @default([]) @map("alternate_primary_answers")
  alternateLearningAnswers  String[] @default([]) @map("alternate_learning_answers")
  createdAt                 DateTime @default(now()) @map("created_at")

  dictionary Dictionary @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)
  vocabPair  VocabPair  @relation(fields: [vocabPairId], references: [id], onDelete: Cascade)

  @@id([dictionaryId, vocabPairId])
  @@index([dictionaryId, nextReviewMs])
  @@map("dictionary_entries")
}

model UserDictionary {
  userId       Int      @map("user_id")
  dictionaryId Int      @map("dictionary_id")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dictionary Dictionary @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)

  @@id([userId, dictionaryId])
  @@index([userId, isDefault])
  @@map("user_dictionaries")
}
