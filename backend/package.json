{
  "name": "vocab-bot-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/with-database-url.mjs migrate deploy && tsx watch src/index.ts",
    "start:prod": "node dist/index.js",
    "build": "npm run build -w @vocab-bot/shared && prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "npm run test:smoke",
    "test:smoke": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "node scripts/with-database-url.mjs db push",
    "db:migrate": "node scripts/with-database-url.mjs migrate deploy",
    "db:deploy": "node scripts/deploy-database.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@prisma/client": "^6.19.0",
    "@vocab-bot/shared": "*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfjs-dist": "^5.7.284",
    "posthog-node": "^5.33.3",
    "postmark": "^4.0.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.19.0",
    "supertest": "^7.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
