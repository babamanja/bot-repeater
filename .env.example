# Local `npm run start` / Prisma CLI — point at your Postgres.
DATABASE_URL=

# Telegram bot token from @BotFather (required to run the bot).
# You can use either name; Docker Compose passes both into the container.
TG_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=

# Docker Compose: copy this file to `.env` next to `docker-compose.yml`, set a token above, then `docker compose up`.
# The `bot` service overrides DATABASE_URL to use the `db` container.
